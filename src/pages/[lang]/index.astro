---
import { Image } from 'astro:assets';
import Layout from '../../layouts/Layout.astro';
import Card from '../../components/Card.astro';
import ReviewsWidget from '../../components/ReviewsWidget.astro';
import { offerings } from '../../data/offerings';
import { useTranslations } from '../../i18n/utils';

// Import Hero Images
import heroDesktop from '../../assets/images/hero-accueil-desktop.webp';
import heroMobile from '../../assets/images/hero-accueil-mobile.webp';

export function getStaticPaths() {
  return [{ params: { lang: 'fr' } }, { params: { lang: 'en' } }];
}

const { lang } = Astro.params;
const t = useTranslations(lang);
const featuredIds = ['cours-collectif', 'exp-camel', 'sejour-libre'];
const featured = featuredIds.map(id => offerings.find(o => o.id === id)!).filter(Boolean);
---

<Layout title={t('nav.home')}>
  <section class="relative h-screen flex items-center justify-center overflow-hidden">
    <div class="absolute inset-0">
      <Image
        src={heroMobile}
        alt="Sidi Kaouki Surf"
        class="w-full h-full object-cover block md:hidden"
        loading="eager"
      />
      <Image
        src={heroDesktop}
        alt="Sidi Kaouki Surf"
        class="w-full h-full object-cover hidden md:block"
        loading="eager"
      />
      <div class="absolute inset-0 bg-gradient-to-b from-dark/30 via-transparent to-dark/60 mix-blend-multiply"></div>
    </div>

    <div class="relative z-10 text-center text-light px-4 mt-10">
      <p class="text-lg md:text-xl uppercase tracking-[0.2em] mb-6 font-medium text-terra drop-shadow-md">
        {t('home.hero.location')}
      </p>
      <h1 class="text-5xl md:text-7xl font-serif font-bold mb-8 drop-shadow-lg">
        {t('home.hero.title')}
      </h1>
      <a href="#book" class="js-open-booking bg-terra hover:bg-terra/90 text-white px-8 py-4 rounded-full text-lg font-medium transition duration-300 inline-block shadow-lg hover:shadow-xl hover:-translate-y-1">
        {t('home.hero.book')}
      </a>
    </div>
  </section>

  <section class="py-10 max-w-4xl mx-auto px-4 text-center">
    <h2 class="text-3xl font-serif text-ocean mb-8">{t('home.welcome.title')}</h2>
    <p class="text-lg text-dark/80 leading-relaxed font-light">
      {t('home.welcome.desc')}
    </p>
  </section>

  <section class="py-12 bg-light">
    <div class="max-w-7xl mx-auto px-4">
      <div class="text-center mb-10">
        <h2 class="text-3xl font-serif text-ocean mb-2">{t('home.popular.title')}</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {featured.map(item => (
          <Card
            title={lang === 'en' ? (item.titleEn || item.title) : item.title}
            priceDisplay={item.priceDisplay}
            image={item.image}
            href={`/${lang}/detail/${item.id}`}
          />
        ))}
      </div>
    </div>
  </section>

  <ReviewsWidget />

  <section class="py-10 bg-light">
    <div class="max-w-xl mx-auto px-4 text-center">
      <!-- ISA logo: drop isa-logo.png into /public/ to display it -->
      <img src="/isa-logo.png" alt="ISA" class="h-20 w-auto object-contain mx-auto mb-4" onerror="this.style.display='none'" />
      <p class="text-stone-500 font-light leading-relaxed">{t('home.isa.desc')}</p>
    </div>
  </section>
</Layout>
