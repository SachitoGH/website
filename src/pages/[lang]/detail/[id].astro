---
import { Image } from 'astro:assets';
import Layout from '../../../layouts/Layout.astro';
import { offerings } from '../../../data/offerings';
import { useTranslations } from '../../../i18n/utils';

export function getStaticPaths() {
  const langs = ['fr', 'en'];
  return langs.flatMap(lang =>
    offerings.map(offer => ({
        params: { lang, id: offer.id },
        props: { offer },
    }))
  );
}

const { lang } = Astro.params;
const { offer } = Astro.props;
const t = useTranslations(lang as any);

const title = lang === 'en' ? (offer.titleEn || offer.title) : offer.title;
const fullDesc = lang === 'en' ? (offer.fullDescEn || offer.fullDesc) : offer.fullDesc;
const features = lang === 'en' ? (offer.featuresEn || offer.features) : offer.features;
const duration = lang === 'en' ? (offer.durationEn || offer.duration) : offer.duration;
const level = lang === 'en' ? (offer.levelEn || offer.level) : offer.level;
---

<Layout title={title}>
  <div class="relative h-56 md:h-80 w-full bg-ocean">
    <Image
      src={offer.image}
      class="w-full h-full object-cover"
      alt={title}
      width={1920}
      height={1080}
      loading="eager"
    />
    <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/20 to-transparent"></div>
    <div class="absolute bottom-0 left-0 w-full p-8 md:p-12 text-white">
      <div class="max-w-7xl mx-auto">
        <span class="bg-terra text-[10px] font-bold px-3 py-1 rounded-full uppercase tracking-[0.2em] mb-4 inline-block">
          {offer.category}
        </span>
        <h1 class="text-4xl md:text-6xl font-serif font-bold">{title}</h1>
      </div>
    </div>
  </div>

  <div class="max-w-7xl mx-auto px-4 py-16 grid grid-cols-1 lg:grid-cols-3 gap-12">
    <div class="lg:col-span-2 space-y-12">
      <div>
        <h2 class="text-2xl font-serif text-ocean mb-6 flex items-center">
          <span class="w-8 h-px bg-terra mr-4"></span>
          {t('detail.about')}
        </h2>
        <p class="text-stone-600 leading-relaxed text-lg whitespace-pre-line">{fullDesc}</p>
      </div>

      <div>
        <h3 class="text-xl font-bold mb-6 text-ocean">{t('detail.included')}</h3>
        <ul class="grid grid-cols-1 sm:grid-cols-2 gap-y-4 gap-x-8">
          {features.map(feature => (
            <li class="flex items-start text-stone-600">
              <svg class="h-5 w-5 text-terra mr-3 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7" />
              </svg>
              {feature}
            </li>
          ))}
        </ul>
      </div>
    </div>

    <div class="relative">
      <div class="sticky top-24 space-y-6">
        <div class="bg-white p-8 rounded-3xl shadow-xl shadow-ocean/5 border border-stone-100">

          {offer.tieredPricing && (
            <div class="mb-8">
              <p class="text-[10px] uppercase tracking-widest text-stone-400 font-bold mb-4">{t('detail.pricing.tiered')}</p>
              <div class="space-y-3">
                {offer.tieredPricing.map(tier => (
                  <div class="flex justify-between items-center p-3 rounded-xl bg-sand/20 border border-sand/50">
                    <span class="text-sm font-medium text-ocean">{tier.guests}</span>
                    <span class="text-lg font-bold text-terra">{tier.price}€</span>
                  </div>
                ))}
              </div>
            </div>
          )}

          {offer.packs && (
            <div class="mb-8">
              <p class="text-[10px] uppercase tracking-widest text-stone-400 font-bold mb-4">{t('detail.pricing.packs')}</p>
              <div class="space-y-3">
                {offer.packs.map(pack => (
                  <div class="flex justify-between items-center p-3 rounded-xl bg-ocean/5 border border-ocean/10">
                    <span class="text-sm font-medium text-ocean">{pack.label}</span>
                    <span class="text-lg font-bold text-ocean">{pack.price}€</span>
                  </div>
                ))}
              </div>
            </div>
          )}

          {!offer.tieredPricing && !offer.packs && (
             <div class="text-center mb-8">
              <p class="text-stone-400 text-xs uppercase tracking-widest">{t('detail.price')}</p>
              <p class="text-4xl font-serif font-bold text-ocean mt-2">{offer.priceDisplay}</p>
            </div>
          )}

          <div class="space-y-4 mb-8 text-sm border-y border-stone-100 py-6">
            <div class="flex justify-between">
              <span class="text-stone-500">{t('detail.duration')}</span>
              <span class="font-bold text-ocean">{duration}</span>
            </div>
            <div class="flex justify-between">
              <span class="text-stone-500">{t('detail.level')}</span>
              <span class="font-bold text-ocean">{level}</span>
            </div>
          </div>

          <button
            data-formula={offer.id}
            class="js-open-booking w-full bg-terra hover:bg-terra-dark text-white font-bold py-4 rounded-2xl transition-all shadow-lg shadow-terra/20 hover:shadow-xl hover:-translate-y-0.5"
          >
            {t('detail.book')}
          </button>

          <p class="text-center text-[10px] text-stone-400 mt-4 uppercase tracking-wider">
            {t('detail.nopayment')}
          </p>
        </div>

        {offer.category === 'sejours' && (
          <div class="bg-ocean text-white p-6 rounded-3xl">
            <p class="text-xs opacity-80 leading-relaxed italic">
              {t('detail.sejours.note')}
            </p>
          </div>
        )}
      </div>
    </div>
  </div>
</Layout>
