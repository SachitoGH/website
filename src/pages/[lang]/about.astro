---
import Layout from '../../layouts/Layout.astro';
import FeaturesGrid from '../../components/FeaturesGrid.astro';
import InstaFeed from '../../components/InstaFeed.astro';
import Team from '../../components/Team.astro';
import { contactFeatures } from '../../data/features';
import { useTranslations } from '../../i18n/utils';

export function getStaticPaths() {
  return [{ params: { lang: 'fr' } }, { params: { lang: 'en' } }];
}

const { lang } = Astro.params;
const t = useTranslations(lang);
---

<Layout title={t('about.meta.title')}>

  <div class="h-56 md:h-80 bg-ocean flex items-center justify-center text-center text-light px-4">
    <div>
      <h1 class="text-4xl md:text-6xl font-serif font-bold">{t('about.hero.title')}</h1>
      <p class="mt-4 text-base md:text-lg text-light/80 max-w-2xl mx-auto">{t('about.hero.subtitle')}</p>
    </div>
  </div>

  <section class="py-10 px-6 text-center">
    <div class="max-w-3xl mx-auto">
        <h2 class="text-3xl font-serif text-ocean mb-8">{t('about.spirit.title')}</h2>
        <p class="text-lg text-stone-600 leading-relaxed font-light mb-6">
            {t('about.spirit.p1')}
        </p>
        <p class="text-lg text-stone-600 leading-relaxed font-light">
            {t('about.spirit.p2')}
        </p>
    </div>
  </section>

  <InstaFeed />

  <Team />

  <FeaturesGrid
    features={contactFeatures.map(f => ({
        ...f,
        title: lang === 'en' ? (f.titleEn || f.title) : f.title,
        description: lang === 'en' ? (f.descriptionEn || f.description) : f.description,
        link: f.link ? {
            ...f.link,
            subText: lang === 'en' ? (f.link.subTextEn || f.link.subText) : f.link.subText
        } : f.link
    }))}
    title={t('about.contact.title')}
    subtitle={t('about.contact.subtitle')}
    bgColor="bg-light"
    iconBgColor="bg-white"
  />

</Layout>
