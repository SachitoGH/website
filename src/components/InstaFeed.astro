---
import { Image } from 'astro:assets';
import { getLangFromUrl, useTranslations } from '../i18n/utils';

import insta1 from '../assets/images/insta-globalsurfsidikaouki-1.webp';
import insta2 from '../assets/images/insta-globalsurfsidikaouki-2.webp';
import insta3 from '../assets/images/insta-globalsurfsidikaouki-3.webp';
import insta4 from '../assets/images/insta-globalsurfsidikaouki-4.webp';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const photos = [insta1, insta2, insta3, insta4];
---

<section class="py-10 bg-light border-t border-stone-200/50">
    <div class="max-w-7xl mx-auto px-4">

        <div class="text-center mb-8">
            <h2 class="text-3xl font-serif text-ocean mb-1">{t('insta.follow')}</h2>
            <a href="https://www.instagram.com/globalsurfsidikaouki/" target="_blank" class="text-sm font-bold uppercase tracking-widest text-terra hover:text-dark transition-colors duration-300">
                @globalsurfsidikaouki
            </a>
        </div>

        <div class="grid grid-cols-2 md:grid-cols-4 gap-4 md:gap-6">
            {photos.map(photo => (
                <a href="https://www.instagram.com/globalsurfsidikaouki/" target="_blank" class="block relative group overflow-hidden rounded-xl aspect-square shadow-sm hover:shadow-md transition-all duration-300">
                    <div class="absolute inset-0 bg-ocean/20 opacity-0 group-hover:opacity-100 transition-opacity duration-300 z-10"></div>
                    <Image
                        src={photo}
                        alt="Global Surf Sidi Kaouki"
                        width={600}
                        height={600}
                        class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
                    />
                </a>
            ))}
        </div>

    </div>
</section>
