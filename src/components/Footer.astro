---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const currentYear = new Date().getFullYear();
---

<footer class="bg-ocean text-sand py-6">
  <div class="max-w-7xl mx-auto px-4 text-center">
    <p class="font-serif text-lg font-bold mb-1">Global Surf</p>
    <p class="text-sm opacity-70 mb-3">{t('footer.location')}</p>
    <p class="text-xs opacity-40">&copy; {currentYear} {t('footer.rights')}</p>
  </div>
</footer>
